# Path-based git attributes
# https://www.kernel.org/pub/software/scm/git/docs/gitattributes.html

# Keep the Composer/Packagist dist archive (`composer require`) lean: exclude
# development, test, and documentation files. Runtime code, config, routes,
# blade views, the Boost guidelines, and the compiled assets in /public are
# kept so the package installs and runs with no build step.

# Repo & CI metadata
/.editorconfig          export-ignore
/.gitattributes         export-ignore
/.github                export-ignore
/.gitignore             export-ignore

# Tests & dev harness
/phpunit.xml.dist       export-ignore
/tests                  export-ignore
/workbench              export-ignore

# Documentation (ADRs + VitePress docs site)
/docs                   export-ignore
/docs-site              export-ignore

# Frontend build toolchain — compiled output ships in /public
/package.json           export-ignore
/package-lock.json      export-ignore
/vite.config.js         export-ignore
/resources/css          export-ignore
/resources/js           export-ignore
